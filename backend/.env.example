# Configuración del Backend - Lender's HQ
# Copia este archivo a .env y completa los valores

# Puerto del servidor
PORT=3000

# URL de PostgreSQL (ajusta según tu configuración)
# Formato: postgresql://usuario:contraseña@host:puerto/nombre_db
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lendershq

# Clave secreta para JWT (cambia en producción)
JWT_SECRET=tu_jwt_secret_aqui

# Tiempo de expiración del JWT
JWT_EXPIRES_IN=7d

# Entorno: development, production, test
NODE_ENV=development