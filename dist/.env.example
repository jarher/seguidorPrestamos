# --- Server Configuration ---
PORT=3001
NODE_ENV=development # change to 'production' for deployment

# --- Database Connections ---
# Development
MONGODB_URI_DEV=localhost:27017
MONGODB_DB_NAME_DEV=lender_hq_dev

# Production (Set these in your hosting provider)
MONGODB_URI_PROD=
MONGODB_DB_NAME_PROD=lender_hq_prod

# --- Security ---
# Generate a long, random string for JWT_SECRET
JWT_SECRET=your_super_secret_jwt_key_here
BCRYPT_SALT_ROUNDS=12

# --- Frontend / CORS ---
# Add your production domain here
CORS_ORIGIN=http://localhost:3000
